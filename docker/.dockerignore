# ======================
# Docker Ignore File
# ======================
# 불필요한 파일을 이미지에서 제외하여 빌드 속도 향상 및 이미지 크기 감소

# Git
.git
.gitignore
.github

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info
dist
build
*.egg
.pytest_cache
.ruff_cache

# Virtual Environment
.venv
venv
ENV
env

# IDE
.vscode
.idea
.cursor
*.swp
*.swo
*~

# Environment
.env
.env.*
!.env.example

# Docker
Dockerfile
docker-compose.local.yml
.dockerignore

# Documentation
docs/
*.md
!README.md

# Testing
tests/
.coverage
htmlcov
.tox

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
