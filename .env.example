# ======================
# FoodDiary Backend 환경변수
# ======================
# 이 파일을 복사하여 .env 파일을 생성하세요:
# cp .env.example .env

# ---------------------------
# 기본 설정
# ---------------------------
DEBUG=false

# ---------------------------
# 외부 API 키
# ---------------------------
# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API
GEMINI_API_KEY=your_api_key_here

# Kakao REST API (지도/장소 검색용)
KAKAO_REST_API_KEY=your_kakao_api_key_here

# ======================
# Google OAuth (필수!)
# ======================
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# 웹 OAuth 테스트용 (선택사항) 🧪
# - /auth/google/login, /auth/google/callback 에서 사용
# - 안드로이드만 쓸 거면 없어도 됨
# 	fooddiary-backend 테스트용 GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ---------------------------
# Database 설정
# ---------------------------
# 로컬 개발 환경용 (Docker 없이 직접 PostgreSQL 실행 시)
# Docker Compose 사용 시: 환경변수로 자동 오버라이드됨
DATABASE_URL=postgresql://changemeid:changemepwd@localhost:5432/fooddiary

# ---------------------------
# API 설정
# ---------------------------
API_PORT=8000

# ---------------------------
# CORS 설정 (쉼표로 구분)
# ---------------------------
CORS_ORIGINS='["http://localhost:3000","https://fooddiary.com"]'

# ======================
# Google OAuth (필수!)
# ======================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ======================
# JWT 설정 (운영 환경에서 반드시 변경!)
# ======================
JWT_SECRET_KEY=

