# ======================
# FoodDiary Backend 환경변수
# ======================
# 이 파일을 복사하여 .env 파일을 생성하세요:
# cp .env.example .env

# ---------------------------
# 기본 설정
# ---------------------------
DEBUG=false

# ---------------------------
# 외부 API 키
# ---------------------------
# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API
GEMINI_API_KEY=your_api_key_here

# Kakao REST API (지도/장소 검색용)
KAKAO_REST_API_KEY=your_kakao_api_key_here

# ---------------------------
# Database 설정
# ---------------------------
# 로컬 개발 환경용 (Docker 없이 직접 PostgreSQL 실행 시)
# Docker Compose 사용 시: 환경변수로 자동 오버라이드됨
DATABASE_URL=postgresql://changemeid:changemepwd@localhost:5432/fooddiary

# ---------------------------
# API 설정
# ---------------------------
API_PORT=8000

# ---------------------------
# CORS 설정 (쉼표로 구분)
# ---------------------------
CORS_ORIGINS='["http://localhost:3000","https://fooddiary.com"]'

# ---------------------------
# OAuth 설정
# ---------------------------

# Apple Sign In
APPLE_CLIENT_ID=com.yourapp.service
APPLE_JWK_URL=https://appleid.apple.com/auth/keys
APPLE_BASE_URL=https://appleid.apple.com

# Google OAuth
# - GOOGLE_CLIENT_ID: 웹 OAuth용 (서버 테스트 시 필수)
# - GOOGLE_ANDROID_CLIENT_ID: 안드로이드 앱용 (배포 시 필수)
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ---------------------------
# JWT 설정
# ---------------------------
# 생성 방법: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here-minimum-32-characters
JWT_ALGORITHM=HS256
# 0 = 만료시간 없음 (MVP 단계)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=0
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=30  # 향후 Refresh Token 추가 시

