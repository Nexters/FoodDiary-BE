# ======================
# FoodDiary Backend 환경변수
# ======================
# 이 파일을 복사하여 .env 파일을 생성하세요:
# cp .env.example .env

# ---------------------------
# 기본 설정
# ---------------------------
DEBUG=false

# ---------------------------
# 외부 API 키
# ---------------------------
# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API
GEMINI_API_KEY=your_api_key_here

# Kakao REST API (지도/장소 검색용)
KAKAO_REST_API_KEY=your_kakao_api_key_here

# ---------------------------
# Database 설정
# ---------------------------
POSTGRES_DB=fooddiary
POSTGRES_USER=fooddiary_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Database URL (자동 생성되지만, 필요시 오버라이드 가능)
# DATABASE_URL=postgresql://fooddiary_user:changeme@localhost:5432/fooddiary

# ---------------------------
# API 설정
# ---------------------------
API_PORT=8000

# ---------------------------
# CORS 설정 (쉼표로 구분)
# ---------------------------
CORS_ORIGINS='["http://localhost:3000","https://fooddiary.com"]'
